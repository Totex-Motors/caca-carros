# Server
PORT=3333
CORS_ORIGIN=http://localhost:5173

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/caca_carros?schema=public

# Auth
JWT_SECRET=change-me
JWT_EXPIRES_IN=8h

# Seed (initial user)
ADMIN_EMAIL=admin@caca.local
ADMIN_PASSWORD=admin123

# Apify / Webmotors provider
APIFY_TOKEN=
APIFY_ACTOR_ID=ribtools/webmotors-scraper
APIFY_TIMEOUT_MS=180000

# OLX / Playwright provider
PROXY_HOST=br.decodo.com
PROXY_PORT=
PROXY_PORTS=
PROXY_USER=
PROXY_PASS=
OLX_ADS_LIMIT=10
OLX_MAX_PAGES=1
OLX_RETRY_ATTEMPTS=2
OLX_NAV_TIMEOUT_MS=45000
OLX_DEBUG_ERRORS=false

# OpenClaw (fallback inteligente, desativado por padrao)
OPENCLAW_ENABLED=false
OPENCLAW_TIMEOUT_MS=6000
OPENCLAW_API_URL=
OPENCLAW_API_PATH=/analyze
OPENCLAW_API_TOKEN=

# Jobs
# Default: every 6 hours
CAR_SEARCH_CRON=0 */6 * * *
CAR_CLEANUP_CRON=0 3 * * *
CAR_RETENTION_DAYS=30
