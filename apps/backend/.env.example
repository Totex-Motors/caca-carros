# Server
PORT=3333
CORS_ORIGIN=http://localhost:5173

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/caca_carros?schema=public

# Auth
JWT_SECRET=change-me
JWT_EXPIRES_IN=8h

# Seed (initial user)
ADMIN_EMAIL=admin@caca.local
ADMIN_PASSWORD=admin123

# Apify / OLX provider
APIFY_TOKEN=
APIFY_ACTOR_ID=israeloriente~olx-cars-scraper
OLX_STATE=sp
OLX_ADS_LIMIT=10
APIFY_TIMEOUT_MS=40000

# Jobs
# Default: every 6 hours
CAR_SEARCH_CRON=0 */6 * * *
CAR_CLEANUP_CRON=0 3 * * *
CAR_RETENTION_DAYS=30
