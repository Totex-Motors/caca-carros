generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WantedCarStatus {
  PENDING
  FOUND
  BOUGHT
  ARCHIVED
}

enum WantedCarCondition {
  NEW
  USED
}

enum WantedCarSellerType {
  PRIVATE
  PROFESSIONAL
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("users")
}

model WantedCar {
  id        String          @id @default(uuid())
  brand     String
  model     String
  version   String?         @map("version")
  clientName String?       @map("client_name")
  clientPhone String?      @map("client_phone")
  seller     String?       
  sellerType WantedCarSellerType? @map("seller_type")
  condition WantedCarCondition? @map("condition")
  yearFrom  Int             @map("year")
  yearTo    Int?            @map("year_to")
  mileageFrom Int?          @map("mileage_from")
  mileageTo Int?            @map("mileage_to")
  maxPrice  Int             @map("max_price")
  status    WantedCarStatus @default(PENDING)
  createdAt DateTime        @default(now()) @map("created_at")

  cars Car[]

  @@map("wanted_cars")
}

model Car {
  id          String   @id @default(uuid())
  brand       String
  model       String
  title       String?
  year        Int
  price       Int
  mileage     Int?
  fuel        String?
  transmission String?
  city        String?
  state       String?
  photos      String[] @default([])
  url         String
  image       String?
  portal      String?
  createdAt   DateTime @default(now()) @map("created_at")
  deletedAt   DateTime? @map("deleted_at")
  wantedCarId String   @map("wanted_car_id")
  wantedCar   WantedCar @relation(fields: [wantedCarId], references: [id], onDelete: Cascade)

  @@unique([wantedCarId, url])
  @@index([wantedCarId])
  @@index([createdAt])
  @@map("cars")
}
